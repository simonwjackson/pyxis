{
  "name": "@pyxis/client",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "PYXIS_WEB_DEV=1 bun --watch server/index.ts",
    "build:web": "vite build",
    "format": "sh -c 'files=$(git diff --name-only --diff-filter=ACMR HEAD -- \"*.ts\" \"*.tsx\" \"*.js\" \"*.jsx\" \"*.json\" \"*.jsonc\" \"*.html\" \"*.css\"); if [ -n \"$files\" ]; then biome check --write $files; fi'",
    "lint": "sh -c 'files=$(git diff --name-only --diff-filter=ACMR HEAD -- \"*.ts\" \"*.tsx\" \"*.js\" \"*.jsx\" \"*.json\" \"*.jsonc\" \"*.html\" \"*.css\"); if [ -n \"$files\" ]; then biome check $files; fi'",
    "typecheck": "bun run typecheck:server && bun run typecheck:web",
    "typecheck:server": "tsc --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "test-unit": "bun test",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "fallow": "fallow",
    "fallow:audit": "fallow audit --config .fallowrc.json",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.60",
    "@effect/platform-bun": "4.0.0-beta.60",
    "@proseql/core": "0.13.2",
    "@proseql/node": "0.13.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.147.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.60",
    "env-paths": "^3.0.0",
    "framer-motion": "^12.28.1",
    "lucide-react": "^0.562.0",
    "nanoid": "^5.1.6",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "proper-lockfile": "^4.1.2",
    "react": "^19",
    "react-dom": "^19",
    "scheduler": "^0.27.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "yaml": "^2.8.2",
    "zod": "3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@storybook/react-vite": "^10.4.1",
    "@tanstack/router-plugin": "^1.157.19",
    "@types/bun": "^1.x",
    "@types/node": "^20.x",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/yaml": "^1.9.7",
    "@vitejs/plugin-react": "^4.5.2",
    "fallow": "^2.84.0",
    "storybook": "^10.4.1",
    "typescript": "^5.x",
    "vite": "^7.0.0"
  }
}
