{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["./src/web/*"],
      "@server/*": ["./server/*"],
      "@shared/api/*": ["./src/api/*"],
      "@shared/sources/*": ["./src/sources/*"],
      "@shared/db/*": ["./src/db/*"],
      "@shared/config": ["./src/config.ts"],
      "@shared/config.js": ["./src/config.ts"],
      "@shared/logger": ["./src/logger.ts"],
      "@shared/logger.js": ["./src/logger.ts"]
    }
  },
  "include": [
    "src/sources/**/*",
    "src/db/**/*",
    "src/logger.ts",
    "server/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-web",
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/web/**/*"
  ]
}
